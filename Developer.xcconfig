// Committed base signing config, referenced by project.yml (configFiles) so
// Xcode/xcodebuild builds sign automatically — same pattern as ../flextunnel-ios.
//
// Do NOT put your Team ID here. Per-developer signing lives in the gitignored
// Developer.local.xcconfig (copy Developer.local.xcconfig.sample and fill it in).
// The optional include below pulls it in when present, so a fresh clone with no
// local file still runs `xcodegen generate` and builds without error.
DEVELOPMENT_TEAM =

// Reverse-DNS prefix for the app + extension bundle ids (project.yml expands
// $(BUNDLE_ID_PREFIX) into PRODUCT_BUNDLE_IDENTIFIER and the keychain group).
// This committed default is the maintainer's own prefix; the App IDs under it
// belong to their team. Sign under a different team by overriding this in
// Developer.local.xcconfig with a prefix your team owns (see the sample), the
// same way you set DEVELOPMENT_TEAM.
BUNDLE_ID_PREFIX = com.andrewtheguy.ezvpn

// Last so a value in Developer.local.xcconfig overrides the defaults above.
#include? "Developer.local.xcconfig"
